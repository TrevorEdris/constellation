+package service
+
+type Manager struct {
+	db       *sql.DB
+	cache    *redis.Client
+	mailer   *smtp.Client
+	logger   *zap.Logger
+	metrics  *prometheus.Registry
+}
+
+func (m *Manager) CreateUser(name, email string) error {
+	_, err := m.db.Exec("INSERT INTO users (name, email) VALUES (?, ?)", name, email)
+	if err != nil { return err }
+	m.cache.Del(context.Background(), "users:list")
+	m.mailer.SendWelcome(email, name)
+	m.metrics.Counter("users.created").Inc()
+	m.logger.Info("user created", zap.String("email", email))
+	return nil
+}
