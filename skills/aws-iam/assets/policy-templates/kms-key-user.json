{
  "_comment": "Policy for an application that uses a KMS CMK to encrypt/decrypt data. Replace ACCOUNT, REGION, KEY_ID. Attach to application role via IAM policy (key policy must also allow this role).",
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowKeyUse",
      "Effect": "Allow",
      "Action": [
        "kms:Decrypt",
        "kms:GenerateDataKey",
        "kms:GenerateDataKeyWithoutPlaintext",
        "kms:DescribeKey"
      ],
      "Resource": [
        "arn:aws:kms:REGION:ACCOUNT:key/KEY_ID"
      ]
    },
    {
      "Sid": "AllowKeyAliasLookup",
      "Effect": "Allow",
      "Action": [
        "kms:ListAliases"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:RequestedRegion": "REGION"
        }
      }
    }
  ]
}
